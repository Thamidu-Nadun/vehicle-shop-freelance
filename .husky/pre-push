#!/bin/sh

set +e

# Colors
MAGENTA="\033[0;35m"
CYAN="\033[0;36m"
BOLD="\033[1m"
RESET="\033[0m"

echo "===================================="
echo "🚀 Pre-Push Hook: Keep Going!"
echo "===================================="
echo ""

echo "Well done! you made it, keep up the good work!"
echo ""

echo -e "${CYAN}Here's a joke for you:${RESET}"
echo ""

joke=$(curl -s --fail -H "Accept: text/plain" https://icanhazdadjoke.com/)

if [ -z "$joke" ]; then
    joke="Why do programmers prefer dark mode? Because light attracts bugs 😄"
fi

echo -e "${MAGENTA}${BOLD}"
echo "╔════════════════════════════════════════════╗"
echo "║              😂  JOKE TIME  😂              ║"
echo "╠════════════════════════════════════════════╣"
echo "$joke" | sed 's/^/║ /' | sed 's/$/ ║/'
echo "╚════════════════════════════════════════════╝"
echo -e "${RESET}"

echo ""
echo "Remember, every push is a step towards greatness. Keep pushing and keep smiling! 😊"

exit 0